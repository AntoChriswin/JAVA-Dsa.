class Solution {
    public int[] divisors(int n) {
        ArrayList<Integer> arr = new ArrayList<>();
        for(int x = n;x>0;x--){
            if(n%x==0){
                arr.add(x);
            }
        }
        Collections.sort(arr);

        // Convert ArrayList to int[]
        int[] result = new int[arr.size()];
        for (int i = 0; i < arr.size(); i++) {
            result[i] = arr.get(i);
        }
        return result;
    }
}
